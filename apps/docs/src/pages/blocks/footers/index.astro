---
import BlocksLayout from '@layouts/BlocksLayout.astro';
import BlockPreview from '@components/blocks/BlockPreview.astro';
import Footer1 from './blocks/_footer1.astro';
import Footer2 from './blocks/_footer2.astro';
import Footer3 from './blocks/_footer3.astro';
import Footer4 from './blocks/_footer4.astro';
import Footer5 from './blocks/_footer5.astro';
---

<BlocksLayout
  title="Footer Sections"
  description="Explore Tailwind CSS footer section examples to organize links, resources, and important information at the bottom of your pages. These blocks include a variety of layouts and styles for clear and structured navigation."
>
  <BlockPreview title="Default footer section" className="min-h-85">
    <Footer1 />
  </BlockPreview>
  <BlockPreview title="Footer with newsletter" className="min-h-120">
    <Footer2 />
  </BlockPreview>
  <BlockPreview title="Multi card footer layout" className="min-h-98">
    <Footer3 />
  </BlockPreview>
  <BlockPreview title="Footer layout with cta" className="min-h-118">
    <Footer4 />
  </BlockPreview>
  <BlockPreview title="E-commerce footer layout" className="min-h-115">
    <Footer5 />
  </BlockPreview>
</BlocksLayout>
