---

<section class="px-6 py-20 max-w-7xl mx-auto">
  <div class="text-center mb-12">
    <h1 class="text-3xl sm:text-4xl mb-4">
      {teamSection.header.title}
    </h1>
    <p class="text-muted sm:text-lg max-w-150 mx-auto">
      {teamSection.header.subtitle}
    </p>
  </div>

  <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 justify-items-center">
    {
      teamSection.members.map((member) => (
        <div class="card text-center border-subtle max-w-80">
          <img
            src={member.image}
            alt={member.name}
            class="card-img-top rounded-full w-32 h-32 object-cover mx-auto mt-6"
          />

          <div class="card-body">
            <h6 class="card-title text-lg font-semibold mb-1">{member.name}</h6>
            <p class="text-sm text-subtle mb-4">{member.role}</p>
            <p class="text-sm text-muted mb-0">{member.bio}</p>
          </div>

          <div class="card-footer flex justify-center gap-2 pb-4">
            {member.actions.map((action) => (
              <a href={action.link} class="btn btn-icon btn-sm hover:text-muted transition">
                {action.type === 'github' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                    <path
                      fill="currentColor"
                      d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"
                    />
                  </svg>
                )}
                {action.type === 'linkedin' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                    <path
                      fill="currentColor"
                      d="M19.707 3H4.347a1.3 1.3 0 0 0-1.306 1.306v15.388c0 .696.58 1.306 1.306 1.306h15.3a1.3 1.3 0 0 0 1.307-1.306V4.277C21.013 3.581 20.432 3 19.707 3M8.354 18.3H5.713V9.735h2.642zM7.019 8.545a1.53 1.53 0 0 1-1.538-1.539c0-.841.696-1.538 1.538-1.538s1.54.697 1.54 1.538s-.64 1.54-1.54 1.54M18.371 18.3h-2.642v-4.152c0-.987-.029-2.293-1.393-2.293c-1.394 0-1.597 1.103-1.597 2.206V18.3h-2.642V9.735h2.584v1.19h.029c.377-.696 1.22-1.393 2.526-1.393c2.7 0 3.193 1.742 3.193 4.123V18.3z"
                    />
                  </svg>
                )}
                {action.type === 'twitter' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                    <path
                      fill="currentColor"
                      d="m17.687 3.063l-4.996 5.711l-4.32-5.711H2.112l7.477 9.776l-7.086 8.099h3.034l5.469-6.25l4.78 6.25h6.102l-7.794-10.304l6.625-7.571zm-1.064 16.06L5.654 4.782h1.803l10.846 14.34z"
                    />
                  </svg>
                )}
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
