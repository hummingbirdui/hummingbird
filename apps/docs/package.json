{
  "name": "@hummingbirdui/docs",
  "private": true,
  "version": "1.1.1",
  "description": "Documentation site for Hummingbird UI",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build",
    "preview": "astro preview",
    "start:docs-js": "esbuild src/docs.ts --bundle --outfile=static/docs.js --watch",
    "deploy": "node deployment.js production",
    "deploy:staging": "node deployment.js staging",
    "deploy:internal": "echo staging.hbui.dev > ./dist/CNAME && gh-pages -d dist -r https://github.com/hummingbirdui/staging.git"
  },
  "dependencies": {
    "@hummingbirdui/browser": "workspace:*",
    "@hummingbirdui/hummingbird": "workspace:*",
    "dedent": "^1.7.2",
    "sharp": "^0.34.5",
    "shiki": "^3.23.0"
  },
  "devDependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@docsearch/css": "^3.9.0",
    "@docsearch/js": "^3.9.0",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^5.18.1",
    "astro-auto-import": "^0.4.6",
    "choices.js": "^11.2.2",
    "dropzone": "6.0.0-beta.2",
    "echarts": "^6.0.0",
    "esbuild": "^0.25.12",
    "flatpickr": "^4.6.13",
    "fs-extra": "^11.3.4",
    "gh-pages": "^6.3.0",
    "gsap": "^3.15.0",
    "is_js": "^0.9.0",
    "nouislider": "^15.8.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.7.3",
    "unist-util-visit": "^5.1.0",
    "vite": "^7.3.2"
  },
  "engines": {
    "node": ">=18"
  }
}
