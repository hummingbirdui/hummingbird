<div class="min-h-screen bg-default flex flex-col items-center justify-center p-6">

  <div class="w-full max-w-100">
    <h1 class="text-4xl text-default tracking-tight mb-4">Login.</h1>
    <p class="text-muted font-medium mb-10">Enter your credentials to access the dashboard.</p>

    <form class="space-y-6 mb-12">
      <div class="form-field group gap-0">
        <label class="form-label text-xs text-default font-bold uppercase tracking-widest opacity-30 group-focus-within:opacity-100 transition-opacity">Email</label>
        <input type="email" placeholder="hello@design.com" 
          class="px-0 py-3 bg-transparent border-b-2 border-light focus:border-black dark:focus:border-white outline-none transition-all placeholder:text-subtle/60 text-lg font-medium">
      </div>

      <div class="form-field group gap-0 mb-8">
        <div class="flex justify-between items-end">
          <label class="form-label text-xs text-default font-bold uppercase tracking-widest opacity-30 group-focus-within:opacity-100 transition-opacity">Password</label>
          <a href="#" class="text-xs font-bold text-default opacity-30 hover:opacity-100 transition">Forgot password?</a>
        </div>
        <input type="password" placeholder="••••••••" 
          class="px-0 py-3 bg-transparent border-b-2 border-light focus:border-black dark:focus:border-white outline-none transition-all placeholder:text-subtle/60 text-lg font-medium">
      </div>

      <button type="submit" 
        class="btn btn-lg btn-neutral dark:bg-white dark:text-black py-3 w-full rounded-full hover:shadow-[0_20px_40px_-10px_rgba(0,0,0,0.3)] transition-all active:scale-[0.98]">
        Continue
      </button>
    </form>

    <p class="text-center text-xs font-bold text-default/30 uppercase tracking-widest mb-6">Quick Connect</p>
    <div class="flex justify-center gap-6">
      <button class="btn btn-square size-12 rounded-2xl bg-subtle shadow-xs dark:border-light">
        <img src="https://www.svgrepo.com/show/355037/google.svg" class="size-6" alt="Google">
      </button>
      <button class="btn btn-square size-12 rounded-2xl bg-subtle shadow-xs dark:border-light">
        <img src="https://www.svgrepo.com/show/448234/linkedin.svg" class="size-8" alt="LinkedIn">
      </button>
      <button class="btn btn-square size-12 rounded-2xl bg-subtle shadow-xs dark:border-light">
        <img src="https://www.svgrepo.com/show/341847/github.svg" class="size-6 dark:invert" alt="GitHub">
      </button>
    </div>

    <p class="mt-12 text-center text-muted font-medium">
      New here? <a href="#" class="text-default font-semibold">Create account</a>
    </p>
  </div>
</div>