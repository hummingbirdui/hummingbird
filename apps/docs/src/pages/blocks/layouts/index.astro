---
import Layout from '@layouts/Layout.astro';
import BlockPreview from '@components/blocks/BlockPreview.astro';
import Layout1 from './blocks/_layout1.astro';
import Layout2 from './blocks/_layout2.astro';
import Layout3 from './blocks/_layout3.astro';
import Layout4 from './blocks/_layout4.astro';
import Layout5 from './blocks/_layout5.astro';
---

<Layout>
  <div class="px-5">
    <div class="max-w-7xl mx-auto my-10">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/" class="link link-hover">Home</a></li>
          <li class="breadcrumb-item"><a href="/blocks" class="link link-hover">Blocks</a></li>
          <li class="breadcrumb-item active" aria-current="page">Layouts</li>
        </ol>
      </nav>
      <h3 class="mb-4 mt-8">Layouts</h3>
      <p class="text-lg">
        Explore a variety of Tailwind CSS layout examples and templates to help you build responsive and visually
        appealing web pages. These layouts are designed and built by the Tailwind CSS team, and include a range of
        different styles and structures to suit various types of websites and applications.
      </p>
      <BlockPreview title="A simple sidebar with navigation grouped by section" className="min-h-225">
        <Layout1 />
      </BlockPreview>
      <BlockPreview title="A responsive sidebar with a search bar" className="min-h-225">
        <Layout2 />
      </BlockPreview>
      <BlockPreview title="A sidebar with collapsible sections" className="min-h-225">
        <Layout3 />
      </BlockPreview>
      <BlockPreview title="A sidebar with submenus as dropdowns" className="min-h-225">
        <Layout4 />
      </BlockPreview>
      <BlockPreview title="Horizontal Navigation" className="min-h-225">
        <Layout5 />
      </BlockPreview>
    </div>
  </div>
</Layout>
