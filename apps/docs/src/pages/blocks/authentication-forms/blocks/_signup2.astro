<div class="min-h-screen flex items-center justify-center p-4 lg:p-8">
  <div class="card lg:flex-row w-full max-w-xl lg:max-w-5xl rounded-3xl overflow-hidden border border-light/60">
    <div class="hidden lg:flex lg:w-9/20 bg-primary-dark dark:bg-primary-light p-12 flex-col relative overflow-hidden">
      <a href="/" class="mb-20">
        <img src="https://themewagon.com/wp-content/themes/themewagon/dist/images/hb.png" alt="Logo" class="h-14 brightness-0 invert">
      </a>

      <h1 class="text-5xl font-bold text-white leading-tight mb-6">
        Join the future <br/> of <span class="text-primary-lighter/80 dark:text-primary-darker/80">data intelligence.</span>
      </h1>
      <p class="text-primary-lighter dark:text-primary-darker text-lg leading-relaxed max-w-sm">
        Empower your team with real-time insights and seamless collaboration.
      </p>

      <div class="mt-auto bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/20">
        <p class="text-white italic">"Setting up our team took minutes. The insights we've gained since are invaluable."</p>
        <div class="mt-4 flex items-center gap-3">
          <div class="avatar">
            <div class="avatar-name rounded-full font-bold text-primary dark:text-primary-light bg-primary-lighter dark:bg-primary-darker">SJ</div>
          </div>
          <div>
            <p class="text-sm font-bold text-white leading-none mb-1.5">Sarah Jenkins</p>
            <p class="text-xs text-white/80 mb-0">Head of Ops at CloudScale</p>
          </div>
        </div>
      </div>
    </div>

    <div class="flex flex-col items-center lg:items-start w-full lg:w-11/20 px-6 py-10 lg:p-16 mx-auto">
      <div class="p-1.25 bg-muted rounded-xl mb-10">
        <button class="btn px-6 bg-transparent text-sm font-medium text-default/60">Sign In</button>
        <button class="btn px-6 bg-default text-sm font-bold text-primary">Sign Up</button>
      </div>

      <h2 class="text-3xl font-extrabold text-default tracking-tight mb-2">Create your account</h2>
      <p class="text-muted mb-8">Start your <span class="font-medium text-primary">14-day free trial</span> today.</p>

      <form class="space-y-5 w-full">
        <div class="grid grid-cols-1 gap-5">
          <div class="form-field">
            <label class="form-label text-sm font-bold text-default/80 mb-1 ms-1.5">Full Name</label>
            <div class="input-group-icon">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5 form-control-icon-start" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <input type="text" class="form-control py-3 rounded-xl border-light focus:border-primary-light focus:ring-4 focus:ring-primary/15 placeholder:text-subtle" placeholder="John Doe" />
            </div>
          </div>

          <div class="form-field">
            <label class="form-label text-sm font-bold text-default/80 mb-1 ms-1.5">Email Address</label>
            <div class="input-group-icon">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5 form-control-icon-start" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <input type="email" class="form-control py-3 rounded-xl border-light focus:border-primary-light focus:ring-4 focus:ring-primary/15 placeholder:text-subtle" placeholder="name@company.com" />
            </div>
          </div>

          <div class="form-field">
            <div class="flex justify-between items-center px-1">
              <label class="form-label text-sm font-bold text-default/80 mb-1 ms-1.5">Password</label>
              <span class="text-[10px] uppercase tracking-wider font-bold text-subtle">Min. 8 Chars</span>
            </div>
            <div class="input-group-icon">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5 form-control-icon-start" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
              <input type="password" class="form-control py-3 rounded-xl border-light focus:border-primary-light focus:ring-4 focus:ring-primary/15 placeholder:text-subtle" placeholder="••••••••" />
            </div>
          </div>
        </div>

        <div class="form-check -mt-4">
          <label for="checkboxDefaultLabel" class="form-check-input-wrapper">
            <input class="form-check-input" type="checkbox" value="" id="checkboxDefaultLabel" />
          </label>
          <label for="checkboxDefaultLabel" class="form-check-label text-xs">
            I agree to the <a href="#" class="text-primary font-medium hover:underline">Terms of Service</a> and <a href="#" class="text-primary font-medium hover:underline">Privacy Policy</a>.
          </label>
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-full rounded-xl">
          Create Account
        </button>
      </form>

      <div class="hr-label my-10 text-[10px] text-default/40 font-bold uppercase tracking-[0.3em] w-full">Or join with</div>
      
      <div class="flex self-center gap-4">
        <button type="button" class="btn btn-outline-neutral btn-lg py-3 border-light rounded-xl">
          <img src="https://www.svgrepo.com/show/355037/google.svg" class="size-5" alt="Google">
        </button>
        <button type="button" class="btn btn-outline-neutral btn-lg py-3 border-light rounded-xl">
          <img src="https://www.svgrepo.com/show/448234/linkedin.svg" class="size-5" alt="LinkedIn">
        </button>
        <button type="button" class="btn btn-outline-neutral btn-lg py-3 border-light rounded-xl">
          <img src="https://www.svgrepo.com/show/341847/github.svg" class="size-5 dark:invert" alt="GitHub">
        </button>
      </div>
    </div>
  </div>
</div>