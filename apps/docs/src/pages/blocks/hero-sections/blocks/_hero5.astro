---
import SearchIcon from '@components/icons/SearchIcon.astro';
---

<div
  class="bg-[url(https://images.unsplash.com/photo-1645033393602-4f7623917853?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D)] bg-no-repeat bg-cover bg-center h-screen"
>
  <div class="bg-linear-to-r from-black/90 to-black/20 w-full h-full absolute top-0 left-0"></div>
  <div class="max-w-7xl mx-auto px-6 md:px-10 h-full flex flex-col justify-between relative z-1">
    <div class="navbar navbar-expand-lg px-0 py-5">
      <a class="navbar-brand flex items-center gap-2 me-0" href="#">
        <button
          class="btn btn-icon navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNavAltMarkup"
          aria-controls="navbarNavAltMarkup"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
            ><path
              fill="currentColor"
              d="M4 18q-.425 0-.712-.288T3 17t.288-.712T4 16h16q.425 0 .713.288T21 17t-.288.713T20 18zm0-5q-.425 0-.712-.288T3 12t.288-.712T4 11h16q.425 0 .713.288T21 12t-.288.713T20 13zm0-5q-.425 0-.712-.288T3 7t.288-.712T4 6h16q.425 0 .713.288T21 7t-.288.713T20 8z"
              stroke-width="0.5"
              stroke="currentColor"></path></svg
          >
        </button>
        <img
          src="https://raw.githubusercontent.com/hummingbirdui/hummingbird/c2a66a70db897fd0d89ea72e7cbab1d3c06a93e2/apps/docs/src/assets/images/logos/hb-logo1.svg"
          alt="Logo"
          class="size-10"
        />
        <h5 class="text-white font-medium hidden sm:block">hummingbird</h5>
      </a>
      <div class="lg:w-46.5 lg:order-1 text-end">
        <a href="#" class="btn btn-primary rounded-full px-6">Sign Up</a>
      </div>
      <div class="collapse navbar-collapse py-6 lg:py-0 grow-0" id="navbarNavAltMarkup">
        <div class="navbar-nav lg:gap-8">
          <a class="nav-link text-white/70 active:text-white active" aria-current="page" href="#">Home</a>
          <a class="nav-link text-white/70 active:text-white" href="#">Features</a>
          <a class="nav-link text-white/70 active:text-white" href="#">Pricing</a>
          <a class="nav-link text-white/70 active:text-white" href="#">Contact</a>
        </div>
      </div>
    </div>
    <div class="max-w-3xl py-16">
      <h1 class="text-4xl sm:text-6xl mb-6 text-white">Let's Explore Now</h1>
      <p class="text-base mb-10 text-white">
        A fast, reliable and easy way to search, compare and book flights, hotels, cars and vacation packages online.
        Get best deals on hotels, flights and car rentals from trusted travel providers worldwide.
      </p>
      <form class="sm:flex items-center bg-white/16 p-4 border border-white/24 rounded-2xl">
        <div class="grid grid-cols-1 sm:grid-cols-3 w-full">
          <div class="max-sm:border-b max-sm:pb-4 max-sm:mb-6 sm:border-e border-white/24 sm:me-6 md:me-10">
            <label class="form-label text-white">Where To?</label>
            <input
              type="text"
              class="form-control px-0 border-0 bg-transparent focus:border-primary focus:ring-0 text-white"
              placeholder="Destination"
            />
          </div>
          <div class="max-sm:border-b max-sm:pb-4 max-sm:mb-6 sm:border-e border-white/24 sm:me-6 md:me-10">
            <label class="form-label text-white">Check-in Date</label>
            <div class="input-group-icon">
              <svg
                onclick="this.nextElementSibling.showPicker()"
                class="form-control-icon-start text-white cursor-pointer inset-s-0"
                xmlns="http://www.w3.org/2000/svg"
                width="1em"
                height="1em"
                viewBox="0 0 24 24"
              >
                <path d="M0 0h24v24H0z" fill="none"></path>
                <path
                  fill="currentColor"
                  d="M5 22q-.825 0-1.412-.587T3 20V6q0-.825.588-1.412T5 4h1V3q0-.425.288-.712T7 2t.713.288T8 3v1h8V3q0-.425.288-.712T17 2t.713.288T18 3v1h1q.825 0 1.413.588T21 6v14q0 .825-.587 1.413T19 22zm0-2h14V10H5zM5 8h14V6H5zm0 0V6z"
                ></path>
              </svg>
              <input
                type="date"
                onclick="this.showPicker()"
                class="form-control ps-6 pe-0 border-0 bg-transparent focus:border-primary focus:ring-0 text-white cursor-pointer [&::-webkit-calendar-picker-indicator]:hidden"
                placeholder="MM/DD/YY"
              />
            </div>
          </div>
          <div class="max-sm:border-b max-sm:pb-4 max-sm:mb-6 sm:border-e border-white/24 sm:me-6 md:me-10">
            <label class="form-label text-white">Number of Guests</label>
            <div class="dropdown">
              <button
                class="btn btn-subtle-neutral p-0 bg-transparent text-white py-1.75 font-normal"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                  <path d="M0 0h24v24H0z" fill="none"></path>
                  <path
                    fill="currentColor"
                    d="M1 17.2q0-.85.438-1.562T2.6 14.55q1.55-.775 3.15-1.162T9 13t3.25.388t3.15 1.162q.725.375 1.163 1.088T17 17.2v.8q0 .825-.587 1.413T15 20H3q-.825 0-1.412-.587T1 18zM21 20h-2.55q.275-.45.413-.962T19 18v-1q0-1.1-.612-2.113T16.65 13.15q1.275.15 2.4.513t2.1.887q.9.5 1.375 1.112T23 17v1q0 .825-.587 1.413T21 20M6.175 10.825Q5 9.65 5 8t1.175-2.825T9 4t2.825 1.175T13 8t-1.175 2.825T9 12t-2.825-1.175m11.65 0Q16.65 12 15 12q-.275 0-.7-.062t-.7-.138q.675-.8 1.038-1.775T15 8t-.362-2.025T13.6 4.2q.35-.125.7-.163T15 4q1.65 0 2.825 1.175T19 8t-1.175 2.825M3 18h12v-.8q0-.275-.137-.5t-.363-.35q-1.35-.675-2.725-1.012T9 15t-2.775.338T3.5 16.35q-.225.125-.363.35T3 17.2zm7.413-8.587Q11 8.825 11 8t-.587-1.412T9 6t-1.412.588T7 8t.588 1.413T9 10t1.413-.587M9 8"
                  ></path>
                </svg>

                1 Person</button
              >
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="#">1 Person</a></li>
                <li><a class="dropdown-item" href="#">2 Persons</a></li>
                <li><a class="dropdown-item" href="#">3 Persons</a></li>
              </ul>
            </div>
          </div>
        </div>
        <button type="submit" class="btn btn-lg btn-primary w-30 px-2"><SearchIcon /> Search</button>
      </form>
    </div>
  </div>
</div>
