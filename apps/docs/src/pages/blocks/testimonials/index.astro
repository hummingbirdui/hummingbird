---
import Layout from '@layouts/Layout.astro';
import BlockPreview from '@components/blocks/BlockPreview.astro';
import Testimonial1 from './blocks/_testimonial1.astro';
import Testimonial2 from './blocks/_testimonial2.astro';
import Testimonial3 from './blocks/_testimonial3.astro';
import Testimonial4 from './blocks/_testimonial4.astro';
import Testimonial5 from './blocks/_testimonial5.astro';
---

<Layout>
  <div class="px-5">
    <div class="max-w-7xl mx-auto my-10">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/" class="link link-hover">Home</a></li>
          <li class="breadcrumb-item"><a href="/blocks" class="link link-hover">Blocks</a></li>
          <li class="breadcrumb-item active" aria-current="page">Testimonials</li>
        </ol>
      </nav>
      <h3 class="mb-4 mt-8">Testimonials</h3>
      <p class="text-lg">
        Explore a variety of Tailwind CSS layout examples and templates to help you build responsive and visually
        appealing web pages. These layouts are designed and built by the Tailwind CSS team, and include a range of
        different styles and structures to suit various types of websites and applications.
      </p>
      <BlockPreview title="A simple sidebar with navigation grouped by section" className="min-h-175">
        <Testimonial1 />
      </BlockPreview>
      <BlockPreview title="A responsive sidebar with a search bar" className="min-h-145">
        <Testimonial2 />
      </BlockPreview>
      <BlockPreview title="A sidebar with collapsible sections" className="min-h-200">
        <Testimonial3 />
      </BlockPreview>
      <BlockPreview title="A sidebar with submenus as dropdowns" className="min-h-158">
        <Testimonial4 />
      </BlockPreview>
      <BlockPreview title="Horizontal Navigation" className="min-h-230">
        <Testimonial5 />
      </BlockPreview>
    </div>
  </div>
</Layout>
