---
import BlocksLayout from '@layouts/BlocksLayout.astro';
import BlockPreview from '@components/blocks/BlockPreview.astro';
import Testimonial1 from './blocks/_testimonial1.astro';
import Testimonial2 from './blocks/_testimonial2.astro';
import Testimonial3 from './blocks/_testimonial3.astro';
import Testimonial4 from './blocks/_testimonial4.astro';
import Testimonial5 from './blocks/_testimonial5.astro';
---

<BlocksLayout
  title="Testimonials"
  description="Explore a collection of Tailwind CSS testimonial section examples designed to highlight customer feedback and build trust with your audience. These layouts feature a variety of styles and structures, making them easy to integrate into any website or product."
>
  <BlockPreview title="Single card testimonial with brand" className="min-h-142">
    <Testimonial1 />
  </BlockPreview>
  <BlockPreview title="Split testimonial card with image" className="min-h-173">
    <Testimonial2 />
  </BlockPreview>
  <BlockPreview title="Split testimonial section with heading" className="min-h-200">
    <Testimonial3 />
  </BlockPreview>
  <BlockPreview title="Minimal spotlight testimonial" className="min-h-143">
    <Testimonial4 />
  </BlockPreview>
  <BlockPreview title="Testimonial section with stats cards" className="min-h-155">
    <Testimonial5 />
  </BlockPreview>
</BlocksLayout>
