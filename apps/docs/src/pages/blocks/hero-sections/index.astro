---
import BlocksLayout from '@layouts/BlocksLayout.astro';
import BlockPreview from '@components/blocks/BlockPreview.astro';
import Hero1 from './blocks/_hero1.astro';
import Hero2 from './blocks/_hero2.astro';
import Hero3 from './blocks/_hero3.astro';
import Hero4 from './blocks/_hero4.astro';
import Hero5 from './blocks/_hero5.astro';
---

<BlocksLayout
  title="Hero sections"
  description="Use these Tailwind CSS hero section examples to add important messaging, product photos, and call-to-actions to the top of your website. These hero examples include a variety of different styles and layouts."
>
  <BlockPreview title="Full-screen overlay with centered content" className="min-h-206">
    <Hero1 />
  </BlockPreview>
  <BlockPreview title="Split with image" className="min-h-206">
    <Hero2 />
  </BlockPreview>
  <BlockPreview title="Centered content with brands logo" className="min-h-252.5">
    <Hero3 />
  </BlockPreview>
  <BlockPreview title="Grid view cards for e-commerce landing" className="min-h-263">
    <Hero4 />
  </BlockPreview>
  <BlockPreview title="Video background" className="min-h-165">
    <Hero5 />
  </BlockPreview>
</BlocksLayout>
