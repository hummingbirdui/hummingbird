---
import BlocksLayout from '@layouts/BlocksLayout.astro';
import BlockPreview from '@components/blocks/BlockPreview.astro';
import CTA1 from './blocks/_cta1.astro';
import CTA2 from './blocks/_cta2.astro';
import CTA3 from './blocks/_cta3.astro';
import CTA4 from './blocks/_cta4.astro';
import CTA5 from './blocks/_cta5.astro';
---

<BlocksLayout
  title="CTA Sections"
  description="Explore Tailwind CSS call-to-action section examples to encourage users to take the next step. These blocks include a variety of layouts and styles to help you create clear and effective actions across your pages."
>
  <BlockPreview title="Simple cta card" className="min-h-185">
    <CTA1 />
  </BlockPreview>
  <BlockPreview title="Split cta section with feature list and image" className="min-h-170">
    <CTA2 />
  </BlockPreview>
  <BlockPreview title="Cta cards with multiple startup options" className="min-h-170">
    <CTA3 />
  </BlockPreview>
  <BlockPreview title="Feature cta panel with stats card" className="min-h-155">
    <CTA4 />
  </BlockPreview>
  <BlockPreview title="Marketing promo cta banner" className='min-h-72'>
    <CTA5 />
  </BlockPreview>
</BlocksLayout>
