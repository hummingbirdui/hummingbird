---
import BlocksLayout from '@layouts/BlocksLayout.astro';
import BlockPreview from '@components/blocks/BlockPreview.astro';
import Pricing1 from './blocks/_pricing1.astro';
import Pricing2 from './blocks/_pricing2.astro';
import Pricing3 from './blocks/_pricing3.astro';
import Pricing4 from './blocks/_pricing4.astro';
import Pricing5 from './blocks/_pricing5.astro';
---

<BlocksLayout
  title="Pricing plans"
  description="Explore a variety of Hummingbird pricing plan examples and templates to help you build responsive and visually appealing web pages. These pricing plans include a range of different styles and structures to suit various types of websites and applications."
>
  <BlockPreview title="Three column card layout with icon" className="min-h-228.5">
    <Pricing1 />
  </BlockPreview>
  <BlockPreview title="Minimal cards with billing toggle" className="min-h-193">
    <Pricing2 />
  </BlockPreview>
  <BlockPreview title="Three column bordered card layout" className="min-h-218">
    <Pricing3 />
  </BlockPreview>
  <BlockPreview title="Grid layout with gradient background accents" className="min-h-315">
    <Pricing4 />
  </BlockPreview>
  <BlockPreview title="Table-based pricing comparison" className="min-h-265">
    <Pricing5 />
  </BlockPreview>
</BlocksLayout>
