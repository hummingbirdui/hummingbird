---
import Layout from '@layouts/Layout.astro';
import BlockPreview from '@components/blocks/BlockPreview.astro';
import Footer1 from './blocks/_footer1.astro';
import Footer2 from './blocks/_footer2.astro';
import Footer3 from './blocks/_footer3.astro';
import Footer4 from './blocks/_footer4.astro';
import Footer5 from './blocks/_footer5.astro';
---

<Layout>
  <div class="px-5">
    <div class="max-w-7xl mx-auto my-10">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/" class="link link-hover">Home</a></li>
          <li class="breadcrumb-item"><a href="/blocks" class="link link-hover">Blocks</a></li>
          <li class="breadcrumb-item active" aria-current="page">Footer Sections</li>
        </ol>
      </nav>
      <h3 class="mb-4 mt-8">Footer Sections</h3>
      <p class="text-lg">
        Explore Tailwind CSS footer section examples to organize links, resources, and important information at the bottom
        of your pages. These blocks include a variety of layouts and styles for clear and structured navigation.
      </p>
      <BlockPreview title="Default footer section" className="min-h-85">
        <Footer1 />
      </BlockPreview>
      <BlockPreview title="Footer with newsletter" className="min-h-120">
        <Footer2 />
      </BlockPreview>
      <BlockPreview title="Multi card footer layout" className="min-h-98">
        <Footer3 />
      </BlockPreview>
      <BlockPreview title="Footer layout with cta" className="min-h-118">
        <Footer4 />
      </BlockPreview>
      <BlockPreview title="E-commerce footer layout" className="min-h-115">
        <Footer5 />
      </BlockPreview>
    </div>
  </div>
</Layout>
