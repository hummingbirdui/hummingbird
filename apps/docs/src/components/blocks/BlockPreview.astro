---
import AppCode from '@components/common/AppCode.astro';
import BulbIcon from '@components/icons/BulbIcon.astro';
import BulbOffIcon from '@components/icons/BulbOffIcon.astro';
import CheckIcon from '@components/icons/CheckIcon.astro';
import ChevronDown from '@components/icons/ChevronDown.astro';
import CodeIcon from '@components/icons/CodeIcon.astro';
import CopyIcon from '@components/icons/CopyIcon.astro';
import Palette from '@components/icons/Palette.astro';
import PreviewIcon from '@components/icons/PreviewIcon.astro';
import { codeBeautify, iframeMarkup } from '@libs/block-utils';

interface Props {
  code?: string;
  lang?: string;
  title?: string;
  className?: string;
}

const { code: codeProp, lang = 'html', title, className } = Astro.props;

const hasSlot = Astro.slots.has('default');
const rawCode = hasSlot ? await Astro.slots.render('default') : (codeProp ?? '');
const code = await codeBeautify(rawCode);
const markup = iframeMarkup(code);

const themes = [
  { value: 'default', label: 'Default' },
  { value: 'luxury', label: 'Luxury' },
  { value: 'retro', label: 'Retro' },
  { value: 'arctic', label: 'Arctic' },
  { value: 'nature', label: 'Nature' },
  { value: 'ember', label: 'Ember' },
  { value: 'dracula', label: 'Dracula' },
  { value: 'midnight', label: 'Midnight' },
];
---

<div id={title?.replace(/\s+/g, '-').toLowerCase()} class="scroll-mt-28">
  <h6 class="mt-14 mb-6 font-medium">
    <a class="no-underline text-default" href={`#${title?.replace(/\s+/g, '-').toLowerCase()}`}>{title}</a>
  </h6>
  <div class="block-preview mb-5">
    <div class="flex mb-3">
      <button class="btn max-sm:btn-square btn-text-neutral gap-1 active me-1" data-btn="show-preview">
        <PreviewIcon />
        <span class="hidden sm:block">Preview</span>
      </button>
      <button class="btn max-sm:btn-square btn-text-neutral gap-1" data-btn="show-code">
        <CodeIcon width="18" height="18" />
        <span class="hidden sm:block">Show code</span>
      </button>
      <div class="dropdown-center ms-auto me-2">
        <button
          class="btn btn-subtle-neutral min-w-36"
          data-bs-toggle="dropdown"
          aria-expanded="false"
          data-bs-auto-close="outside"
        >
          <Palette />
          <span data-block-theme-dropdown-label>Default</span>
          <ChevronDown />
        </button>
        <ul class="dropdown-menu min-w-66" role="menu">
          {
            themes.map(({ value, label }, index) => (
              <li role="none">
                <a
                  class="dropdown-item flex items-center justify-between"
                  href="#"
                  data-block-theme-dropdown-item
                  data-theme={value}
                  role="menuitem"
                >
                  {label}
                  <div class="flex gap-1">
                    <div
                      class={`size-3.5 border border-default rounded ${index === 0 ? 'bg-[#1e90ff] dark:bg-[#4da7ff]' : 'bg-primary'}`}
                    />
                    <div
                      class={`size-3.5 border border-default rounded ${index === 0 ? 'bg-[#ac49fc] dark:bg-[#bc70fb]' : 'bg-secondary'}`}
                    />
                    <div
                      class={`size-3.5 border border-default rounded ${index === 0 ? 'bg-white dark:bg-[#07080a]' : 'bg-default'}`}
                    />
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <button class="btn btn-square btn-subtle-neutral me-2" data-btn="theme">
        <BulbIcon width="20" height="20" data-theme-icon-light />
        <BulbOffIcon width="20" height="20" class="hidden" data-theme-icon-dark />
      </button>
      <button class="btn btn-square btn-subtle-neutral" data-btn="copy-code">
        <CopyIcon data-copy-icon />
        <CheckIcon width="28" height="28" class="text-success hidden" data-check-icon />
      </button>
    </div>
    <div class="w-full" data-stage="stage">
      <div class="flex">
        <div data-element="iframe-wrap" class="rounded-2xl relative w-full border border-subtle/50">
          <div class="h-10 rounded-t-2xl bg-muted px-4 flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
          <iframe
            data-element="preview-frame"
            srcdoc={markup}
            title="Component preview"
            sandbox="allow-scripts allow-same-origin allow-forms allow-popups"
            class={`w-full rounded-b-2xl ${className}`}></iframe>
          <div class="h-full w-1 absolute -right-4 top-0 px-2 flex items-center cursor-ew-resize" data-handle="resize">
            <div class="w-1.5 h-8 bg-emphasis cursor-ew-resize shrink-0 rounded-full"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="bg-subtle overflow-x-auto hidden p-4 border border-subtle/50 rounded-2xl" data-stage="code-stage">
      <AppCode code={code} lang={lang} data-astro-code />
    </div>
  </div>
</div>
<script>
  (() => {
    const DARK_CLASS = 'dark';
    const HIDDEN_CLASS = 'hidden';
    const ACTIVE_CLASS = 'active';
    const MIN_IFRAME_WIDTH = 375;

    const getDocumentIsDark = () => document.documentElement.classList.contains(DARK_CLASS);

    document.querySelectorAll('.block-preview').forEach((container) => {
      const iframeWrap = container.querySelector<HTMLElement>('[data-element="iframe-wrap"]');
      const iframe = container.querySelector<HTMLIFrameElement>('[data-element="preview-frame"]');
      const previewStage = container.querySelector<HTMLElement>('[data-stage="stage"]');
      const codeStage = container.querySelector<HTMLElement>('[data-stage="code-stage"]');
      const resizeHandle = container.querySelector<HTMLElement>('[data-handle="resize"]');
      const showCodeBtn = container.querySelector<HTMLElement>('[data-btn="show-code"]');
      const previewBtn = container.querySelector<HTMLElement>('[data-btn="show-preview"]');
      const themeBtn = container.querySelector<HTMLElement>('[data-btn="theme"]');
      const copyBtn = container.querySelector<HTMLElement>('[data-btn="copy-code"]');
      const codeContainer = codeStage?.querySelector('[data-astro-code]');

      if (!iframeWrap || !iframe) return;

      // ─── Iframe auto-height ───────────────────────────────────────────────

      const syncIframeHeight = () => {
        try {
          const body = iframe.contentDocument?.body;
          const docEl = iframe.contentDocument?.documentElement;
          if (!body || !docEl) return;

          iframe.style.height = '0px';
          docEl.style.overflow = 'visible';
          body.style.overflow = 'visible';

          const height = Math.max(body.scrollHeight, docEl.scrollHeight);
          iframe.style.height = `${height}px`;
        } catch {}
      };

      const initIframeObserver = (): boolean => {
        try {
          const body = iframe.contentDocument?.body;
          if (!body) return false;

          syncIframeHeight();
          new ResizeObserver(syncIframeHeight).observe(body);

          body.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            if (target.closest('a')) e.preventDefault();
          });

          return true;
        } catch {
          return false;
        }
      };

      const waitForIframe = () => {
        if (!initIframeObserver()) requestAnimationFrame(waitForIframe);
      };

      waitForIframe();

      // ─── Code / Preview toggle ────────────────────────────────────────────

      showCodeBtn?.addEventListener('click', () => {
        showCodeBtn.classList.add(ACTIVE_CLASS);
        previewBtn?.classList.remove(ACTIVE_CLASS);
        codeStage?.classList.remove(HIDDEN_CLASS);
        previewStage?.classList.add(HIDDEN_CLASS);
      });

      previewBtn?.addEventListener('click', () => {
        showCodeBtn?.classList.remove(ACTIVE_CLASS);
        previewBtn.classList.add(ACTIVE_CLASS);
        codeStage?.classList.add(HIDDEN_CLASS);
        previewStage?.classList.remove(HIDDEN_CLASS);
      });

      // ─── Iframe resize handle ─────────────────────────────────────────────

      let isResizing = false;
      let dragStartX = 0;
      let dragStartWidth = 0;

      resizeHandle?.addEventListener('mousedown', (e) => {
        isResizing = true;
        dragStartX = e.clientX;
        dragStartWidth = iframeWrap.offsetWidth;
        document.body.style.cursor = 'ew-resize';
        document.body.style.userSelect = 'none';
        iframe.style.pointerEvents = 'none';
      });

      const onMouseMove = (e: MouseEvent) => {
        if (!isResizing) return;
        const newWidth = dragStartWidth + (e.clientX - dragStartX);
        if (newWidth > MIN_IFRAME_WIDTH) {
          iframeWrap.style.width = `${newWidth}px`;
          syncIframeHeight(); // ← sync on every drag tick
        }
      };

      const onResizeEnd = () => {
        if (!isResizing) return;
        isResizing = false;
        document.body.style.cursor = '';
        document.body.style.userSelect = '';
        iframe.style.pointerEvents = 'auto';
        syncIframeHeight(); // ← sync once more on release
      };

      document.addEventListener('mousemove', onMouseMove);
      document.addEventListener('mouseup', onResizeEnd);
      document.addEventListener('mouseleave', onResizeEnd);

      // ─── Copy code button ────────────────────────────────────────────────
      const copyIcon = copyBtn?.querySelector('[data-copy-icon]');
      const copyCheckIcon = copyBtn?.querySelector('[data-check-icon]');

      let revertTimer: ReturnType<typeof setTimeout> | null = null;
      copyBtn?.addEventListener('click', async () => {
        if (!codeContainer || !copyBtn) return;

        const codeText = ((codeContainer as HTMLElement).innerText ?? codeContainer.textContent ?? '').trim();
        if (!codeText) return;

        try {
          await navigator.clipboard.writeText(codeText);

          copyCheckIcon?.classList.remove(HIDDEN_CLASS);
          copyIcon?.classList.add(HIDDEN_CLASS);

          if (revertTimer) clearTimeout(revertTimer);
          revertTimer = setTimeout(() => {
            copyCheckIcon?.classList.add(HIDDEN_CLASS);
            copyIcon?.classList.remove(HIDDEN_CLASS);
          }, 1600);
        } catch {}
      });

      // ─── Theme sync ───────────────────────────────────────────────────────
      const blockThemeItems = container.querySelectorAll<HTMLElement>('[data-block-theme-dropdown-item]');
      const blockThemeDropDownLabel = container.querySelector<HTMLElement>('[data-block-theme-dropdown-label]');

      let iframeIsDark = getDocumentIsDark();
      let iframeMainTheme = localStorage.getItem('main-theme') || 'default';
      const iconLight = container.querySelector<HTMLElement>('[data-theme-icon-light]');
      const iconDark = container.querySelector<HTMLElement>('[data-theme-icon-dark]');

      const applyThemeToIframe = () => {
        const docEl = iframe.contentDocument?.documentElement;
        if (!docEl) return;
        docEl.classList.toggle(DARK_CLASS, iframeIsDark);
        docEl.setAttribute('data-theme', iframeMainTheme);
        if (iframeIsDark) {
          iconLight?.classList.add(HIDDEN_CLASS);
          iconDark?.classList.remove(HIDDEN_CLASS);
        } else {
          iconLight?.classList.remove(HIDDEN_CLASS);
          iconDark?.classList.add(HIDDEN_CLASS);
        }
      };

      applyThemeToIframe();

      new MutationObserver(() => {
        iframeIsDark = getDocumentIsDark();
        applyThemeToIframe();
        blockThemeItems.forEach((item) => {
          if (iframeIsDark) {
            item.classList.add(DARK_CLASS);
          } else {
            item.classList.remove(DARK_CLASS);
          }
        });
      }).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

      themeBtn?.addEventListener('click', () => {
        iframeIsDark = !iframeIsDark;
        applyThemeToIframe();
      });

      let activeTheme = 'default';
      let activeItem = Array.from(blockThemeItems).find((item) => item.dataset.theme === activeTheme) || null;
      activeItem?.classList.add('active');

      blockThemeItems.forEach((item) => {
        item.addEventListener('click', (e) => {
          e.preventDefault();
          const theme = item.dataset.theme;
          if (theme) {
            iframeMainTheme = theme;
            applyThemeToIframe();
          }

          activeItem?.classList.remove('active');
          item.classList.add('active');
          activeItem = item;
          blockThemeDropDownLabel && (blockThemeDropDownLabel.innerText = item.innerText);
        });
      });
    });
  })();
</script>
