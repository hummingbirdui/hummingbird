---
import { Component } from '@data/components.astro';
import { getVersionedPath } from '@libs/config';

interface Props {
  component: Component;
}

const { component } = Astro.props;
const { url, imgComponent: ImageComponent, title, count } = component;
---

<a
  href={getVersionedPath(url)}
  class="card card-action flex flex-col h-full w-full rounded-2xl bg-default overflow-hidden hover:border-primary"
>
  <div class="grow flex items-center justify-center bg-subtle p-4 aspect-4/3">
    <ImageComponent />
  </div>
  <div class="px-4 py-3">
    <h6 class="card-title mb-0.5 text-base font-semibold">{title}</h6>
    <p class="mb-0 text-xs text-muted">{count} components</p>
  </div>
</a>
