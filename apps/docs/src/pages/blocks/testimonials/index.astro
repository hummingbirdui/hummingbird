---
import Layout from '@layouts/Layout.astro';
import BlockPreview from '@components/blocks/BlockPreview.astro';
import Testimonial1 from './blocks/_testimonial1.astro';
import Testimonial2 from './blocks/_testimonial2.astro';
import Testimonial3 from './blocks/_testimonial3.astro';
import Testimonial4 from './blocks/_testimonial4.astro';
import Testimonial5 from './blocks/_testimonial5.astro';
---

<Layout>
  <div class="px-5">
    <div class="max-w-7xl mx-auto my-10">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/" class="link link-hover">Home</a></li>
          <li class="breadcrumb-item"><a href="/blocks" class="link link-hover">Blocks</a></li>
          <li class="breadcrumb-item active" aria-current="page">Testimonials</li>
        </ol>
      </nav>
      <h3 class="mb-4 mt-8">Testimonials</h3>
      <p class="text-lg">
        Explore a collection of Tailwind CSS testimonial section examples designed to highlight customer feedback and build trust with your audience. These layouts feature a variety of styles and structures, making them easy to integrate into any website or product.
      </p>
      <BlockPreview title="Single card testimonial with brand" className="min-h-142">
        <Testimonial1 />
      </BlockPreview>
      <BlockPreview title="Split testimonial card with image" className="min-h-173">
        <Testimonial2 />
      </BlockPreview>
      <BlockPreview title="Split testimonial section with heading" className="min-h-200">
        <Testimonial3 />
      </BlockPreview>
      <BlockPreview title="Minimal spotlight testimonial" className="min-h-143">
        <Testimonial4 />
      </BlockPreview>
      <BlockPreview title="Testimonial section with stats cards" className="min-h-155">
        <Testimonial5 />
      </BlockPreview>
    </div>
  </div>
</Layout>
