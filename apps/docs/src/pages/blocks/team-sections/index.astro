---
import Layout from '@layouts/Layout.astro';
import BlockPreview from '@components/blocks/BlockPreview.astro';
import Team1 from './blocks/_team1.astro';
import Team2 from './blocks/_team2.astro';
import Team3 from './blocks/_team3.astro';
import Team4 from './blocks/_team4.astro';
import Team5 from './blocks/_team5.astro';
---

<Layout>
  <div class="px-5">
    <div class="max-w-7xl mx-auto my-10">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/" class="link link-hover">Home</a></li>
          <li class="breadcrumb-item"><a href="/blocks" class="link link-hover">Blocks</a></li>
          <li class="breadcrumb-item active" aria-current="page">Testimonials</li>
        </ol>
      </nav>
      <h3 class="mb-4 mt-8">Testimonials</h3>
      <p class="text-lg">
        Explore a collection of Tailwind CSS testimonial section examples designed to highlight customer feedback and build trust with your audience. These layouts feature a variety of styles and structures, making them easy to integrate into any website or product.
      </p>
      <BlockPreview title="Single Card Testimonial with Brand" className="min-h-142">
        <Team1 />
      </BlockPreview>
      <BlockPreview title="Single Card Testimonial with Brand" className="min-h-142">
        <Team2 />
      </BlockPreview>
      <BlockPreview title="Single Card Testimonial with Brand" className="min-h-142">
        <Team3 />
      </BlockPreview>
      <BlockPreview title="Single Card Testimonial with Brand" className="min-h-142">
        <Team4 />
      </BlockPreview>
      <BlockPreview title="Single Card Testimonial with Brand" className="min-h-142">
        <Team5 />
      </BlockPreview>
    </div>
  </div>
</Layout>
